[t:template,n:lyottia_12_soul_lance]
{
	specializes = base_arrow;
	[aspect]
	{
		model=m_w_misc_023;
		scale_base = 1.0;
		force_no_render = true;
		draw_selection_indicator = false;
        [textures]
        {
            0 = b_w_misc_lyottia_soul_lance_01;
        }
	}
	[attack]
	{
		damage_max = 2;
		damage_min = 1;
		skill_class = "Combat Magic";
	}
	[body]
	{
		[bone_translator]
		{
			handle = ap_grip;
			middle = ap_tip;
			tip = ap_tip;
		}
	}
	[common]
	{
		screen_name = "Lance";
		[template_triggers]
		{
			[*]
			{
				action* = call_sfx_script("soul_lance_dust");
				condition* = receive_world_message("WE_ENTERED_WORLD");
				single_shot = true;
			}
		}
	}
	[physics]
	{
		angular_velocity = 0,0,10.0;
		gravity = 0;
		explode_if_hit_go = true;
		explode_if_hit_terrain = true;
		explode_when_expired = true;
		break_effect = ice_explosion;
		sim_duration = 10;
	}
}