[fae_queen_distraught]
{
	[text*]
	{
		activate_quest* = lyottia_quest_31_sanctum,4;
		screen_text = "Woe is us! The mighty seck shepherd has seized control of my beloved sisters. They are but a magic fuel to him. I have failed, I have most horribly failed...";
	  f scroll_rate = 10.000000;
	}
}
[lyottia_conversation_32_fae_queen_quest_start]
{
	[text*]
	{
		screen_text = "Destroy the Sheppard! Help me release my beloved fae from his bidding! I will royally reward you!";
	  f scroll_rate = 10.000000;
	}
}
[lyottia_conversation_32_fae_queen_quest_end_first]
{
	[text*]
	{
		screen_text = "Blessed be the ice, my fae are free of the evil seck will. But at what cost? Take you reward stranger, and leave us to mourn our sisters.";
	  f scroll_rate = 10.000000;
	}
}
[lyottia_conversation_32_fae_queen_quest_end_next]
{
	[text*]
	{
		screen_text = "Blesses be, kind one. My fae are free of the evil seck will. But at what cost?";
	  f scroll_rate = 10.000000;
	}
}
[seck_guide]
{
	[text*]
	{
		screen_text = "Oh, the great young hero smashed the lexicon and saved the world, huh? Have you congratulated yourself already? To me, it seems like you smashed to pieces the rukenberry pie recipe I placed there after I recovered its secrets. The lexicon's knowledge is ours now, and your world shall perish. Also, did you think the magic barrier you destroyed was the unqiue mechanism designed to resist the seck powers? Fooled again. Farewell, and face the full might of the lexicon's true guardians.";
	  f scroll_rate = 10.000000;
	}
}