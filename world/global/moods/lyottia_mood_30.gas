[mood_setting*]
{
	mood_name				= lyottia_30_general;
	transition_time			= 0.0f;

	interior				= false;
	[fog]
	{
		fog_near_dist		= 25.0f;
		fog_far_dist		= 50.0f;
		fog_lowdetail_near_dist		= 25.0f;
		fog_lowdetail_far_dist		= 45.0f;
		fog_color			= 0x00f192ff;
		fog_density			= 0.5f;
	}

	// Snowing
	[snow]
	{
		snow_density		= 400;
	}

	[music]
	{
		ambient_track		= "";
		ambient_repeat_delay	= 35.0f;
        
		standard_repeat_delay = 10.0f;
		standard_track		= "s_m_emily_GatheringArmies";
		room_type			= rt_generic;
	}
}